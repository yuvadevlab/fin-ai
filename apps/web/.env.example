# ==============================================================================
# FinAI Web Frontend Local Environment Template (apps/web/.env.example)
# ==============================================================================

# API Proxy Endpoint
NEXT_PUBLIC_API_URL=http://localhost:4000

# Page Navigation Flags
NEXT_PUBLIC_PAGE_SETTINGS=true
NEXT_PUBLIC_PAGE_AI_ADVISOR=true

# Feature Flags
NEXT_PUBLIC_FEATURE_ACCOUNTS=true
NEXT_PUBLIC_FEATURE_AI_ADVISOR=true
NEXT_PUBLIC_FEATURE_AI_INSIGHT=true
NEXT_PUBLIC_FEATURE_BUDGETS=true
NEXT_PUBLIC_FEATURE_FAMILY=true
NEXT_PUBLIC_FEATURE_GOALS=true
NEXT_PUBLIC_FEATURE_HEALTH=true
NEXT_PUBLIC_FEATURE_INVESTMENTS=true
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=true
NEXT_PUBLIC_FEATURE_REPORTS=true
NEXT_PUBLIC_FEATURE_SEARCH=true
NEXT_PUBLIC_FEATURE_SETTINGS=true
NEXT_PUBLIC_FEATURE_TRANSACTIONS=true
