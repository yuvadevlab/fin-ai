datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum WorkspaceType {
  PERSONAL
  FAMILY
}

enum GoalType {
  PERSONAL
  FAMILY
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum AccountType {
  BANK
  CREDIT_CARD
  WALLET
  CASH
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  INVESTMENT
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum AssetClass {
  MUTUAL_FUND
  STOCK
  FIXED_DEPOSIT
  GOLD
  EPF
  PPF
  REAL_ESTATE
  CRYPTO
  OTHER
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum NotificationType {
  BUDGET_WARNING
  BUDGET_EXCEEDED
  GOAL_COMPLETED
  GOAL_MILESTONE
  AI_INSIGHT
  WORKSPACE_INVITE
  SYSTEM
}

model User {
  id           String            @id @default(uuid())
  email        String            @unique
  name         String
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  conversations Conversation[]
  notifications Notification[]
  workspacesOwned Workspace[]
}

model Workspace {
  id        String            @id @default(uuid())
  name      String
  type      WorkspaceType     @default(PERSONAL)
  ownerId   String
  owner     User              @relation(fields: [ownerId], references: [id])
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  accounts  Account[]
  transactions Transaction[]
  categories Category[]
  budgets   Budget[]
  goals     Goal[]
  investments Investment[]
  conversations Conversation[]
}

model WorkspaceMember {
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  @@id([workspaceId, userId])
}

model Account {
  id           String        @id @default(uuid())
  workspaceId  String
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  type         AccountType
  balance      Float         @default(0.0)
  currency     String        @default("INR")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id          String          @id @default(uuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  amount      Float
  merchant    String
  date        DateTime
  notes       String?
  type        TransactionType
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Category {
  id          String        @id @default(uuid())
  workspaceId String?
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  group       String
  icon        String?
  isSystem    Boolean       @default(false)
  transactions Transaction[]
  budgets     Budget[]

  @@unique([workspaceId, name])
}

model Budget {
  id          String       @id @default(uuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  limit       Float
  period      BudgetPeriod @default(MONTHLY)
  startDate   DateTime     @default(now())

  @@unique([workspaceId, categoryId])
}

model Goal {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Float
  currentAmount Float     @default(0.0)
  deadline      DateTime
  type          GoalType  @default(PERSONAL)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Investment {
  id             String     @id @default(uuid())
  workspaceId    String
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String
  assetClass     AssetClass
  currentValue   Float
  investedAmount Float
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Conversation {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}
